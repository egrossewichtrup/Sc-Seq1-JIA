#!/usr/bin/env bash
# Save me as run_souporcell.sh, then: bash run_souporcell.sh
# You can also override at call time, e.g.:
#   CAPTURE_ID=C3 K=3 BAM=/path/to.bam BARCODES_GZ=/path/to/barcodes.tsv.gz bash run_souporcell.sh

set -euo pipefail

#####################################
# === USER SETTINGS (edit here) === #
#####################################
# Output/project root (results + tmp + scripts)
PROJ="${PROJ:-/hpc/dla_lti/yermanos_group/GRO11679/genetic_demultiplexing}"

# 10x reference FASTA (will index if needed)
REF_FASTA="${REF_FASTA:-/hpc/dla_lti/yermanos_group/REF_GEX/refdata-gex-GRCh38-2024-A/fasta/genome.fa}"

# If you want auto-derivation of BAM and barcodes, set CR_RUN_ROOT to the root that contains per-capture "multi_<CAPTURE_ID>_bam"
# Example:
CR_RUN_ROOT="${CR_RUN_ROOT:-/hpc/dla_lti/yermanos_group/GRO11679/analysis_20250925_140348/cellranger_multi_RERUN_BAM}"

# Conda (Miniforge) and env for souporcell
MINIFORGE_ROOT="${MINIFORGE_ROOT:-/hpc/dla_lti/yermanos_group/software/venvs4/miniforge3}"
CONDA_ENV_PATH="${CONDA_ENV_PATH:-/hpc/dla_lti/yermanos_group/software/venvs4/souporcell}"

# Default capture + donors K (override via env or edit here)
CAPTURE_ID="${CAPTURE_ID:-C1}"
K="${K:-2}"

# Optional email notifications (leave empty to disable)
MAIL_USER="${MAIL_USER:-egrossewichtrup@umcutrecht.nl}"

#####################################
# === (Usually no edits below)  === #
#####################################

mkdir -p "${PROJ}/scripts" "${PROJ}/demux" "${PROJ}/tmp"

# If BAM/BARCODES_GZ are not provided, try to derive them from CR_RUN_ROOT + CAPTURE_ID
if [[ -z "${BAM:-}" ]]; then
  BAM="${CR_RUN_ROOT}/multi_${CAPTURE_ID}/multi_${CAPTURE_ID}_bam/outs/per_sample_outs/multi_${CAPTURE_ID}_bam/count/sample_alignments.bam"
fi
if [[ -z "${BARCODES_GZ:-}" ]]; then
  BARCODES_GZ="${CR_RUN_ROOT}/multi_${CAPTURE_ID}/multi_${CAPTURE_ID}_bam/outs/per_sample_outs/multi_${CAPTURE_ID}_bam/count/sample_filtered_feature_bc_matrix/barcodes.tsv.gz"
fi

# Basic checks now (fail early if clearly wrong)
for p in "$REF_FASTA" "$BAM" "$BARCODES_GZ" "$MINIFORGE_ROOT"; do
  if [[ ! -e "$p" ]]; then
    echo "[ERROR] Path not found: $p" >&2
  fi
done

SBATCH_FILE="${PROJ}/scripts/run_souporcell_${CAPTURE_ID}.sbatch"

cat > "$SBATCH_FILE" <<'SBATCH'
#!/usr/bin/env bash
#SBATCH --job-name=souporcell_${CAPTURE_ID}
#SBATCH --time=24:00:00
#SBATCH --cpus-per-task=8
#SBATCH --mem=120G
#SBATCH --chdir=${PROJ}
#SBATCH --output=%x_%j.out
#SBATCH --error=%x_%j.err
#SBATCH --mail-type=END,FAIL
#MAILTAG

set -euo pipefail

echo "[INFO] Starting souporcell for capture ${CAPTURE_ID} at: $(date)"

# Exported by the launcher (this file is a template)
PROJ="${PROJ}"
REF_FASTA="${REF_FASTA}"
BAM="${BAM}"
BARCODES_GZ="${BARCODES_GZ}"
CAPTURE_ID="${CAPTURE_ID}"
K="${K}"
MINIFORGE_ROOT="${MINIFORGE_ROOT}"
CONDA_ENV_PATH="${CONDA_ENV_PATH}"

# Timestamped output
TS="$(date +%Y%m%d_%H%M%S)"
OUTROOT="${PROJ}/demux/genetic_demultiplexing_${TS}"
OUTDIR="${OUTROOT}/${CAPTURE_ID}_souporcell"
mkdir -p "${OUTDIR}"

# Job-local temp in project
JOBTMP="${PROJ}/tmp/souporcell_${CAPTURE_ID}_${SLURM_JOB_ID}_${TS}"
mkdir -p "${JOBTMP}"
export TMPDIR="$JOBTMP"
export TMP="$JOBTMP"
export TEMP="$JOBTMP"
export BCFTOOLS_TMP_DIR="$JOBTMP"

echo "[INFO] Output root: ${OUTROOT}"
echo "[INFO] Outdir:      ${OUTDIR}"
echo "[INFO] Temp dir:    ${JOBTMP}"

# Activate conda env (disable nounset briefly for 'source')
set +u
source "${MINIFORGE_ROOT}/etc/profile.d/conda.sh"
conda activate "${CONDA_ENV_PATH}"
set -u

# Tool sanity
command -v souporcell_pipeline.py >/dev/null 2>&1 || { echo "[ERROR] souporcell_pipeline.py not found in env"; exit 2; }
command -v samtools >/dev/null 2>&1 || { echo "[ERROR] samtools not found in env"; exit 2; }

# Input checks
[[ -s "${REF_FASTA}" ]] || { echo "[ERROR] FASTA missing: ${REF_FASTA}" >&2; exit 2; }
[[ -s "${BAM}" ]] || { echo "[ERROR] BAM missing: ${BAM}" >&2; exit 2; }
[[ -s "${BARCODES_GZ}" ]] || { echo "[ERROR] barcodes.tsv.gz missing: ${BARCODES_GZ}" >&2; exit 2; }

# Disk info for PROJ (temp + output live here)
df -h "${PROJ}" || true

# FASTA index if needed
[[ -f "${REF_FASTA}.fai" ]] || samtools faidx "${REF_FASTA}"

# Ensure BAM is indexed
[[ -f "${BAM}.bai" ]] || samtools index "${BAM}"

# Souporcell expects uncompressed barcodes.tsv
BARCODES_TSV="${OUTDIR}/barcodes.tsv"
if [[ ! -s "${BARCODES_TSV}" ]]; then
  gunzip -c "${BARCODES_GZ}" > "${BARCODES_TSV}"
fi

echo "[INFO] Running Souporcell: K=${K}, threads=${SLURM_CPUS_PER_TASK}"
souporcell_pipeline.py \
  -i "${BAM}" \
  -b "${BARCODES_TSV}" \
  -f "${REF_FASTA}" \
  -t "${SLURM_CPUS_PER_TASK}" \
  -o "${OUTDIR}" \
  -k "${K}"

echo "[DONE] Souporcell ${CAPTURE_ID} finished at $(date)"
echo "[DONE] Outputs in: ${OUTDIR}"
SBATCH

# If mail user given, inject it, else strip mail line
if [[ -n "$MAIL_USER" ]]; then
  sed -i "s|#MAILTAG|#SBATCH --mail-user=${MAIL_USER}|" "$SBATCH_FILE"
else
  sed -i "s|#MAILTAG||" "$SBATCH_FILE"
fi

# Substitute variables safely in the sbatch template
# (Use perl for robust literal replacement)
perl -pi -e "s|\$\{PROJ\}|$PROJ|g" "$SBATCH_FILE"
perl -pi -e "s|\$\{REF_FASTA\}|$REF_FASTA|g" "$SBATCH_FILE"
perl -pi -e "s|\$\{BAM\}|$BAM|g" "$SBATCH_FILE"
perl -pi -e "s|\$\{BARCODES_GZ\}|$BARCODES_GZ|g" "$SBATCH_FILE"
perl -pi -e "s|\$\{CAPTURE_ID\}|$CAPTURE_ID|g" "$SBATCH_FILE"
perl -pi -e "s|\$\{K\}|$K|g" "$SBATCH_FILE"
perl -pi -e "s|\$\{MINIFORGE_ROOT\}|$MINIFORGE_ROOT|g" "$SBATCH_FILE"
perl -pi -e "s|\$\{CONDA_ENV_PATH\}|$CONDA_ENV_PATH|g" "$SBATCH_FILE"

chmod +x "$SBATCH_FILE"

echo "[INFO] Submitting: $SBATCH_FILE"
JOBID=$(sbatch "$SBATCH_FILE" | awk '{print $4}')
echo "[SUBMITTED] ${CAPTURE_ID} — JobID: ${JOBID}"
echo "[TIP] Change CAPTURE_ID and K up top (or pass env vars) to reuse this script for other captures."
