extract_one_selected_node <- function(sample_id,
                                      target_clonotype_id,
                                      selected_node,
                                      af_obj,
                                      vdj_obj) {
  
  vdj_cols <- colnames(vdj_obj)
  
  sample_root <- get_sample_root(af_obj, sample_id)
  af_key <- find_af_key(sample_root, target_clonotype_id)
  clono_obj <- sample_root[[af_key]]
  
  if (!(selected_node %in% names(clono_obj$nodes))) {
    stop(
      "Node ", selected_node,
      " not found in AF object for ", sample_id, " ", target_clonotype_id
    )
  }
  
  node <- clono_obj$nodes[[selected_node]]
  
  af_node_barcodes <- unique(as.character(node$barcodes))
  af_node_size <- as.integer(node$size)[1]
  
  node_heavy_aa <- as.character(node$VDJ_sequence_aa_trimmed)[1]
  node_light_aa <- as.character(node$VJ_sequence_aa_trimmed)[1]
  
  vdj_barcode_subset <- vdj_obj %>%
    mutate(barcode = as.character(barcode)) %>%
    filter(barcode %in% af_node_barcodes) %>%
    add_count(barcode, name = "n_vdj_rows_for_this_barcode") %>%
    mutate(
      barcode_found_in_vdj = TRUE,
      clonotype_match = as.character(clonotype_id) == target_clonotype_id,
      heavy_aa_match = as.character(VDJ_sequence_aa_trimmed) == node_heavy_aa,
      light_aa_match = as.character(VJ_sequence_aa_trimmed) == node_light_aa,
      aa_pair_match = heavy_aa_match & light_aa_match
    )
  
  matched_vdj <- vdj_barcode_subset %>%
    filter(aa_pair_match)
  
  sequence_pick <- pick_top_sequence_bundle(matched_vdj)
  
  n_af_barcodes <- length(af_node_barcodes)
  n_vdj_rows_with_af_barcodes <- nrow(vdj_barcode_subset)
  n_vdj_unique_barcodes_with_af_barcodes <- dplyr::n_distinct(vdj_barcode_subset$barcode)
  n_vdj_rows_matching_node_aa <- nrow(matched_vdj)
  n_vdj_unique_barcodes_matching_node_aa <- dplyr::n_distinct(matched_vdj$barcode)
  
  af_vdj_barcode_count_match <- n_af_barcodes == n_vdj_unique_barcodes_matching_node_aa
  af_size_matches_barcodes <- af_node_size == n_af_barcodes
  af_size_matches_vdj_unique_barcodes <- af_node_size == n_vdj_unique_barcodes_matching_node_aa
  
  qc_found <- vdj_barcode_subset %>%
    mutate(
      Sample_id = sample_id,
      target_clonotype_id = target_clonotype_id,
      af_key = af_key,
      selected_node = selected_node,
      af_node_size = af_node_size,
      n_af_barcodes = n_af_barcodes,
      n_vdj_rows_with_af_barcodes = n_vdj_rows_with_af_barcodes,
      n_vdj_unique_barcodes_with_af_barcodes = n_vdj_unique_barcodes_with_af_barcodes,
      n_vdj_rows_matching_node_aa = n_vdj_rows_matching_node_aa,
      n_vdj_unique_barcodes_matching_node_aa = n_vdj_unique_barcodes_matching_node_aa,
      af_vdj_barcode_count_match = af_vdj_barcode_count_match,
      af_size_matches_barcodes = af_size_matches_barcodes,
      af_size_matches_vdj_unique_barcodes = af_size_matches_vdj_unique_barcodes,
      selected_node_VDJ_sequence_aa_trimmed = node_heavy_aa,
      selected_node_VJ_sequence_aa_trimmed = node_light_aa
    ) %>%
    select(
      Sample_id,
      target_clonotype_id,
      af_key,
      selected_node,
      af_node_size,
      n_af_barcodes,
      n_vdj_rows_with_af_barcodes,
      n_vdj_unique_barcodes_with_af_barcodes,
      n_vdj_rows_matching_node_aa,
      n_vdj_unique_barcodes_matching_node_aa,
      barcode_found_in_vdj,
      n_vdj_rows_for_this_barcode,
      clonotype_match,
      heavy_aa_match,
      light_aa_match,
      aa_pair_match,
      all_of(vdj_cols),
      af_vdj_barcode_count_match,
      af_size_matches_barcodes,
      af_size_matches_vdj_unique_barcodes,
      selected_node_VDJ_sequence_aa_trimmed,
      selected_node_VJ_sequence_aa_trimmed
    )
  
  missing_barcodes <- setdiff(af_node_barcodes, vdj_barcode_subset$barcode)
  
  qc_missing_vdj <- as_tibble(vdj_obj[rep(NA_integer_, length(missing_barcodes)), , drop = FALSE])
  
  if (length(missing_barcodes) > 0) {
    qc_missing_vdj$barcode <- missing_barcodes
  }
  
  qc_missing <- qc_missing_vdj %>%
    mutate(
      Sample_id = sample_id,
      target_clonotype_id = target_clonotype_id,
      af_key = af_key,
      selected_node = selected_node,
      af_node_size = af_node_size,
      n_af_barcodes = n_af_barcodes,
      n_vdj_rows_with_af_barcodes = n_vdj_rows_with_af_barcodes,
      n_vdj_unique_barcodes_with_af_barcodes = n_vdj_unique_barcodes_with_af_barcodes,
      n_vdj_rows_matching_node_aa = n_vdj_rows_matching_node_aa,
      n_vdj_unique_barcodes_matching_node_aa = n_vdj_unique_barcodes_matching_node_aa,
      barcode_found_in_vdj = FALSE,
      n_vdj_rows_for_this_barcode = 0L,
      clonotype_match = NA,
      heavy_aa_match = NA,
      light_aa_match = NA,
      aa_pair_match = NA,
      af_vdj_barcode_count_match = af_vdj_barcode_count_match,
      af_size_matches_barcodes = af_size_matches_barcodes,
      af_size_matches_vdj_unique_barcodes = af_size_matches_vdj_unique_barcodes,
      selected_node_VDJ_sequence_aa_trimmed = node_heavy_aa,
      selected_node_VJ_sequence_aa_trimmed = node_light_aa
    ) %>%
    select(
      Sample_id,
      target_clonotype_id,
      af_key,
      selected_node,
      af_node_size,
      n_af_barcodes,
      n_vdj_rows_with_af_barcodes,
      n_vdj_unique_barcodes_with_af_barcodes,
      n_vdj_rows_matching_node_aa,
      n_vdj_unique_barcodes_matching_node_aa,
      barcode_found_in_vdj,
      n_vdj_rows_for_this_barcode,
      clonotype_match,
      heavy_aa_match,
      light_aa_match,
      aa_pair_match,
      all_of(vdj_cols),
      af_vdj_barcode_count_match,
      af_size_matches_barcodes,
      af_size_matches_vdj_unique_barcodes,
      selected_node_VDJ_sequence_aa_trimmed,
      selected_node_VJ_sequence_aa_trimmed
    )
  
  qc_table <- bind_rows(qc_found, qc_missing) %>%
    arrange(barcode)
  
  production_row <- tibble(
    Sample_id = sample_id,
    patient_id = first_nonempty(node$patient_id),
    clonotype_id = target_clonotype_id,
    selected_node = selected_node,
    
    af_node_size = af_node_size,
    n_vdj_unique_barcodes_matching_node_aa = n_vdj_unique_barcodes_matching_node_aa,
    
    sequence_selection_rule = "node_pure_selected_AF_node_with_matching_VDJ_rows",
    annotation_selection_rule = "mode_across_matching_barcodes_within_node_ties_joined_by_semicolon",
    observed_isotypes_in_node = collapse_unique(node$isotype),
    
    VDJ_vgene = most_common_by_barcode(matched_vdj, "VDJ_vgene"),
    VDJ_dgene = most_common_by_barcode(matched_vdj, "VDJ_dgene"),
    VDJ_jgene = most_common_by_barcode(matched_vdj, "VDJ_jgene"),
    VDJ_cgene = most_common_by_barcode(matched_vdj, "VDJ_cgene"),
    
    VJ_vgene = most_common_by_barcode(matched_vdj, "VJ_vgene"),
    VJ_jgene = most_common_by_barcode(matched_vdj, "VJ_jgene"),
    VJ_cgene = most_common_by_barcode(matched_vdj, "VJ_cgene"),
    
    VDJ_cdr3_nt = most_common_by_barcode(matched_vdj, "VDJ_cdr3_nt"),
    VDJ_cdr3_aa = most_common_by_barcode(matched_vdj, "VDJ_cdr3_aa"),
    VJ_cdr3_nt = most_common_by_barcode(matched_vdj, "VJ_cdr3_nt"),
    VJ_cdr3_aa = most_common_by_barcode(matched_vdj, "VJ_cdr3_aa"),
    
    VDJ_sequence_nt_trimmed = sequence_pick$selected_VDJ_sequence_nt_trimmed,
    VJ_sequence_nt_trimmed = sequence_pick$selected_VJ_sequence_nt_trimmed,
    barcode = sequence_pick$barcode,
    n_barcodes_supporting_selected_nt_pair = sequence_pick$n_barcodes_supporting_selected_nt_pair,
    
    VDJ_sequence_aa_trimmed = node_heavy_aa,
    VJ_sequence_aa_trimmed = node_light_aa
  )
  
  list(
    production = production_row,
    qc = qc_table
  )
}

