first_nonempty <- function(x) {
  x <- as.character(x)
  x <- x[!is.na(x) & trimws(x) != ""]
  if (length(x) == 0) return(NA_character_)
  x[[1]]
}

collapse_unique <- function(x) {
  x <- as.character(x)
  x <- x[!is.na(x) & trimws(x) != ""]
  x <- sort(unique(x))
  if (length(x) == 0) return(NA_character_)
  paste(x, collapse = ";")
}

collapse_semicolon_sets <- function(x) {
  x <- as.character(x)
  x <- x[!is.na(x) & trimws(x) != ""]
  if (length(x) == 0) return(NA_character_)
  
  parts <- unlist(strsplit(x, ";", fixed = TRUE))
  parts <- trimws(parts)
  parts <- parts[parts != ""]
  parts <- sort(unique(parts))
  
  if (length(parts) == 0) return(NA_character_)
  paste(parts, collapse = ";")
}

most_common_by_barcode <- function(df, value_col, barcode_col = "barcode") {
  if (nrow(df) == 0) return(NA_character_)
  
  tmp <- tibble(
    barcode = as.character(df[[barcode_col]]),
    value = as.character(df[[value_col]])
  ) %>%
    filter(!is.na(value), trimws(value) != "") %>%
    distinct(barcode, value) %>%
    count(value, name = "n_barcodes", sort = TRUE)
  
  if (nrow(tmp) == 0) return(NA_character_)
  
  max_n <- max(tmp$n_barcodes, na.rm = TRUE)
  
  top_values <- tmp %>%
    filter(n_barcodes == max_n) %>%
    arrange(value) %>%
    pull(value)
  
  paste(top_values, collapse = ";")
}

get_sample_root <- function(af_obj, sample_id) {
  if (!is.null(af_obj[[sample_id]])) return(af_obj[[sample_id]])
  af_obj[[1]]
}

find_af_key <- function(sample_root, clonotype_id) {
  hits <- grep(paste0("\\.", clonotype_id, "$"), names(sample_root), value = TRUE)
  
  if (length(hits) != 1) {
    stop(
      "Could not find exactly one AF key for ", clonotype_id,
      ". Found: ", paste(hits, collapse = ", ")
    )
  }
  
  hits[[1]]
}

###############################################################################
# This helper picks one representative sequence bundle:
# 1. choose the most prevalent paired NT sequence across unique barcodes
# 2. from that exact NT pair, choose one barcode deterministically
# 3. return the matching NT + AA + barcode together
###############################################################################
pick_top_sequence_bundle <- function(df,
                                     barcode_col = "barcode",
                                     heavy_nt_col = "VDJ_sequence_nt_trimmed",
                                     light_nt_col = "VJ_sequence_nt_trimmed",
                                     heavy_aa_col = "VDJ_sequence_aa_trimmed",
                                     light_aa_col = "VJ_sequence_aa_trimmed") {
  
  out_na <- tibble(
    selected_VDJ_sequence_nt_trimmed = NA_character_,
    selected_VJ_sequence_nt_trimmed = NA_character_,
    selected_VDJ_sequence_aa_trimmed = NA_character_,
    selected_VJ_sequence_aa_trimmed = NA_character_,
    barcode = NA_character_,
    n_barcodes_supporting_selected_nt_pair = NA_integer_
  )
  
  if (nrow(df) == 0) return(out_na)
  
  tmp <- tibble(
    barcode = as.character(df[[barcode_col]]),
    VDJ_sequence_nt_trimmed = as.character(df[[heavy_nt_col]]),
    VJ_sequence_nt_trimmed = as.character(df[[light_nt_col]]),
    VDJ_sequence_aa_trimmed = as.character(df[[heavy_aa_col]]),
    VJ_sequence_aa_trimmed = as.character(df[[light_aa_col]])
  ) %>%
    filter(
      !is.na(barcode), trimws(barcode) != "",
      !is.na(VDJ_sequence_nt_trimmed), trimws(VDJ_sequence_nt_trimmed) != "",
      !is.na(VJ_sequence_nt_trimmed), trimws(VJ_sequence_nt_trimmed) != "",
      !is.na(VDJ_sequence_aa_trimmed), trimws(VDJ_sequence_aa_trimmed) != "",
      !is.na(VJ_sequence_aa_trimmed), trimws(VJ_sequence_aa_trimmed) != ""
    ) %>%
    distinct(
      barcode,
      VDJ_sequence_nt_trimmed,
      VJ_sequence_nt_trimmed,
      VDJ_sequence_aa_trimmed,
      VJ_sequence_aa_trimmed
    )
  
  if (nrow(tmp) == 0) return(out_na)
  
  top_nt_pair <- tmp %>%
    distinct(barcode, VDJ_sequence_nt_trimmed, VJ_sequence_nt_trimmed) %>%
    count(
      VDJ_sequence_nt_trimmed,
      VJ_sequence_nt_trimmed,
      name = "n_barcodes_supporting_selected_nt_pair",
      sort = TRUE
    ) %>%
    arrange(
      desc(n_barcodes_supporting_selected_nt_pair),
      VDJ_sequence_nt_trimmed,
      VJ_sequence_nt_trimmed
    ) %>%
    slice(1)
  
  representative_row <- tmp %>%
    semi_join(
      top_nt_pair,
      by = c("VDJ_sequence_nt_trimmed", "VJ_sequence_nt_trimmed")
    ) %>%
    arrange(barcode, VDJ_sequence_aa_trimmed, VJ_sequence_aa_trimmed) %>%
    slice(1)
  
  tibble(
    selected_VDJ_sequence_nt_trimmed = representative_row$VDJ_sequence_nt_trimmed,
    selected_VJ_sequence_nt_trimmed = representative_row$VJ_sequence_nt_trimmed,
    selected_VDJ_sequence_aa_trimmed = representative_row$VDJ_sequence_aa_trimmed,
    selected_VJ_sequence_aa_trimmed = representative_row$VJ_sequence_aa_trimmed,
    barcode = representative_row$barcode,
    n_barcodes_supporting_selected_nt_pair = top_nt_pair$n_barcodes_supporting_selected_nt_pair
  )
}

